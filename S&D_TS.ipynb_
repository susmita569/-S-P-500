ta';\n","          await google.colab.output.renderOutput(dataTable, element);\n","          const docLink = document.createElement('div');\n","          docLink.innerHTML = docLinkHtml;\n","          element.appendChild(docLink);\n","        }\n","      </script>\n","    </div>\n","  </div>\n","  "],"text/plain":["                open      high       low     close   volume   Name\n","date                                                              \n","2013-02-08  390.4551  393.7283  390.1698  393.0777  6031199  GOOGL\n","2013-02-11  389.5892  391.8915  387.2619  391.6012  4330781  GOOGL\n","2013-02-12  391.2659  394.3440  390.0747  390.7403  3714176  GOOGL\n","2013-02-13  390.4551  393.0677  390.3750  391.8214  2393946  GOOGL\n","2013-02-14  390.2549  394.7644  389.2739  394.3039  3466971  GOOGL"]},"metadata":{},"execution_count":60}]},{"cell_type":"code","source":["GL1 = GL.copy()"],"metadata":{"id":"XePykqnwXa2D"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["GL1.close.head()"],"metadata":{"id":"MqGKe-7rX5eS","outputId":"58b53b03-bc88-426c-ee62-80747cf7090d","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["date\n","2013-02-08    393.0777\n","2013-02-11    391.6012\n","2013-02-12    390.7403\n","2013-02-13    391.8214\n","2013-02-14    394.3039\n","Name: close, dtype: float64"]},"metadata":{},"execution_count":62}]},{"cell_type":"markdown","source":["# Modeling For LSTM"],"metadata":{"id":"konyGeiMrXkl"}},{"cell_type":"code","source":["# Import libraries\n","import numpy as np\n","import pandas as pd\n","import matplotlib.pyplot as plt\n","import os\n","\n","from statsmodels.tsa.seasonal import seasonal_decompose\n","from statsmodels.tsa.stattools import adfuller\n","\n","import tensorflow as tf\n","from tensorflow.keras.models import Sequential\n","from tensorflow.keras.layers import Dense, Dropout, LSTM"],"metadata":{"id":"0aEYxneTP_Z8"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Convert data to  stationary\n","def test_stationarity(timeseries):\n","    '''\n","    Input: timeseries (dataframe): timeseries for which we want to study the stationarity\n","    '''\n","\n","    #Determing rolling statistics\n","    rolmean = timeseries.rolling(20).mean()\n","    rolstd = timeseries.rolling(20).std()\n","\n","    #Plot rolling statistics:\n","    orig = plt.plot(timeseries, color='blue',label='Original')\n","    mean = plt.plot(rolmean, color='red', label='Rolling Mean')\n","    std = plt.plot(rolstd, color='black', label = 'Rolling Std')\n","    plt.legend(loc='best')\n","    plt.title('Rolling Mean & Standard Deviation')\n","    plt.show(block=False)\n","\n","    #Perform Dickey-Fuller test:\n","    print('Results of Dickey-Fuller Test:')\n","    dftest = adfuller(timeseries, autolag='AIC')\n","    dfoutput = pd.Series(dftest[0:4], index=['Test Statistic','p-value',\\\n","                                             '#Lags Used','Number of Observations Used'])\n","    for key,value in dftest[4].items():\n","        dfoutput['Critical Value (%s)'%key] = value\n","    print(dfoutput)"],"metadata":{"id":"JrSG8O-DPK6c"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["plt.figure(figsize = (10,6))\n","test_stationarity(GL.close.head(2000))"],"metadata":{"id":"7vyHuzktPiFF","outputId":"8e65e36c-3eb0-4183-b1cf-a3e3149f4401","colab":{"base_uri":"https://localhost:8080/","height":543}},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 720x432 with 1 Axes>"]},"metadata":{"needs_background":"light"}},{"output_type":"stream","name":"stdout","text":["Results of Dickey-Fuller Test:\n","Test Statistic                   -0.533822\n","p-value                           0.885246\n","#Lags Used                        1.000000\n","Number of Observations Used    1257.000000\n","Critical Value (1%)              -3.435563\n","Critical Value (5%)              -2.863842\n","Critical Value (10%)             -2.567996\n","dtype: float64\n"]}]},{"cell_type":"code","source":["GL.close_log = GL.close.apply(np.log)\n","GL.close_tf = GL.close_log.apply(np.sqrt)\n","\n","plt.figure(figsize = (10,6))\n","plt.plot(GL.close_tf)\n","plt.title('Transformed data')"],"metadata":{"id":"wJKAQCPAQcnt","outputId":"cca42c1a-58a3-4198-dab6-7abec1cc3578","colab":{"base_uri":"https://localhost:8080/","height":407}},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["Text(0.5, 1.0, 'Transformed data')"]},"metadata":{},"execution_count":66},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 720x432 with 1 Axes>"]},"metadata":{"needs_background":"light"}}]},{"cell_type":"code","source":["print(GL.close_tf)"],"metadata":{"id":"mT-YW9TaUgGf","outputId":"0a9cd224-0f3e-496e-81e1-07da0f9a9c79","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["date\n","2013-02-08    2.444178\n","2013-02-11    2.443408\n","2013-02-12    2.442958\n","2013-02-13    2.443523\n","2013-02-14    2.444815\n","                ...   \n","2018-02-01    2.659815\n","2018-02-02    2.649598\n","2018-02-05    2.639749\n","2018-02-06    2.643636\n","2018-02-07    2.638500\n","Name: close, Length: 1259, dtype: float64\n"]}]},{"cell_type":"code","source":["GL.close = GL.close_tf - GL.close_tf.shift()\n","GL_close_shift=GL.close.dropna()\n","plt.figure(figsize = (10,6))\n","test_stationarity(GL_close_shift)\n"],"metadata":{"id":"O_bfLBKZQsaV","outputId":"d1cc5d50-b9d2-47fd-ede5-62e2ff51ff44","colab":{"base_uri":"https://localhost:8080/","height":543}},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 720x432 with 1 Axes>"]},"metadata":{"needs_background":"light"}},{"output_type":"stream","name":"stdout","text":["Results of Dickey-Fuller Test:\n","Test Statistic                  -33.929046\n","p-value                           0.000000\n","#Lags Used                        0.000000\n","Number of Observations Used    1257.000000\n","Critical Value (1%)              -3.435563\n","Critical Value (5%)              -2.863842\n","Critical Value (10%)             -2.567996\n","dtype: float64\n"]}]},{"cell_type":"markdown","source":["# 15 Univariate LSTM Models"],"metadata":{"id":"PR4ffdw4v0KW"}},{"cell_type":"code","source":["import tensorflow as tf\n","from tensorflow.keras.models import Sequential\n","from tensorflow.keras.layers import Dense, Dropout, LSTM"],"metadata":{"id":"HSlyw1rPEtS_"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["-It is special kind of Recurrent Neural Network (RNN)used for long term dependencies"],"metadata":{"id":"BLdlccPq5UyA"}},{"cell_type":"markdown","source":["# 15.1 Vanilla model"],"metadata":{"id":"k3DwKVN45nOz"}},{"cell_type":"code","source":["def preprocess_lstm(sequence, n_steps,n_features):\n","    X, y = list(), list()\n","    for i in range(len(sequence)):\n","        # find the end of this pattern\n","        end_ix = i + n_steps\n","        # check if we are beyond the sequence\n","        if end_ix >= len(sequence):\n","            break\n","        # gather input and output parts of the pattern\n","        seq_x, seq_y = sequence[i:end_ix], sequence[end_ix]\n","        X.append(seq_x)\n","        y.append(seq_y)\n","\n","    X = np.array(X)\n","    y = np.array(y)\n","\n","    X = X.reshape((X.shape[0], X.shape[1], n_features))\n","    return X, y"],"metadata":{"id":"1Smn2J5e4j6p"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# choose the number of days on which to base our predictions\n","nb_days = 60\n","\n","n_features = 1\n","\n","X, y = preprocess_lstm(GL_close_shift.to_numpy(), nb_days, n_features)"],"metadata":{"id":"IU1pmtHB4o7K"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["#Split the data set between the training set and the test set\n","test_days = 365\n","\n","X_train, y_train = X[:-test_days], y[:-test_days]\n","X_test, y_test = X[-test_days:], y[-test_days:]"],"metadata":{"id":"UbgYFnEE4pAc"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["train_original = GL1.close[:-test_days]\n","test_original = GL1.close[-test_days:]\n","\n","plt.figure(figsize=(10,6))\n","plt.grid(True)\n","plt.xlabel('Dates')\n","plt.ylabel('Closing Prices')\n","plt.plot(train_original, 'b', label='Train data')\n","plt.plot(test_original, 'g', label='Test data')\n","plt.legend()"],"metadata":{"id":"sQWl9Hss4pDa","outputId":"d2fc6bf0-2165-4e34-da2c-98306d06e033","colab":{"base_uri":"https://localhost:8080/","height":405}},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["<matplotlib.legend.Legend at 0x7f9b0bf8fc50>"]},"metadata":{},"execution_count":73},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 720x432 with 1 Axes>"]},"metadata":{"needs_background":"light"}}]},{"cell_type":"code","source":["def vanilla_LSTM():\n","    model = Sequential()\n","    model.add(LSTM(units=50, input_shape=(nb_days, n_features)))\n","    model.add(Dense(1))\n","    return model"],"metadata":{"id":"5zw4WSDg5LOK"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["model = vanilla_LSTM()\n","model.summary()\n","model.compile(optimizer='adam',\n","              loss='mean_squared_error',\n","              metrics=[tf.keras.metrics.MeanAbsoluteError()])"],"metadata":{"id":"BWrC4dnM5A20","outputId":"89d97674-44a1-4385-f68d-3b42ba60d21b","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Model: \"sequential\"\n","_________________________________________________________________\n"," Layer (type)                Output Shape              Param #   \n","=================================================================\n"," lstm (LSTM)                 (None, 50)                10400     \n","                                                                 \n"," dense (Dense)               (None, 1)                 51        \n","                                                                 \n","=================================================================\n","Total params: 10,451\n","Trainable params: 10,451\n","Non-trainable params: 0\n","_________________________________________________________________\n"]}]},{"cell_type":"code","source":["model.fit(X_train,\n","          y_train,\n","          epochs=15,\n","          batch_size = 32)"],"metadata":{"id":"358tWij95A5O","outputId":"e71786dc-7e91-46e9-9227-0f96f57c8c57","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Epoch 1/15\n","27/27 [==============================] - 3s 24ms/step - loss: 1.8155e-05 - mean_absolute_error: 0.0031\n","Epoch 2/15\n","27/27 [==============================] - 1s 22ms/step - loss: 9.8045e-06 - mean_absolute_error: 0.0022\n","Epoch 3/15\n","27/27 [==============================] - 1s 21ms/step - loss: 9.3119e-06 - mean_absolute_error: 0.0021\n","Epoch 4/15\n","27/27 [==============================] - 1s 21ms/step - loss: 9.3271e-06 - mean_absolute_error: 0.0021\n","Epoch 5/15\n","27/27 [==============================] - 1s 22ms/step - loss: 8.9647e-06 - mean_absolute_error: 0.0020\n","Epoch 6/15\n","27/27 [==============================] - 1s 22ms/step - loss: 1.0060e-05 - mean_absolute_error: 0.0022\n","Epoch 7/15\n","27/27 [==============================] - 1s 22ms/step - loss: 9.7054e-06 - mean_absolute_error: 0.0022\n","Epoch 8/15\n","27/27 [==============================] - 1s 23ms/step - loss: 9.0819e-06 - mean_absolute_error: 0.0021\n","Epoch 9/15\n","27/27 [==============================] - 1s 23ms/step - loss: 1.1046e-05 - mean_absolute_error: 0.0024\n","Epoch 10/15\n","27/27 [==============================] - 1s 24ms/step - loss: 1.2960e-05 - mean_absolute_error: 0.0027\n","Epoch 11/15\n","27/27 [==============================] - 1s 23ms/step - loss: 9.4454e-06 - mean_absolute_error: 0.0022\n","Epoch 12/15\n","27/27 [==============================] - 1s 22ms/step - loss: 9.5423e-06 - mean_absolute_error: 0.0021\n","Epoch 13/15\n","27/27 [==============================] - 1s 23ms/step - loss: 8.8581e-06 - mean_absolute_error: 0.0020\n","Epoch 14/15\n","27/27 [==============================] - 1s 23ms/step - loss: 9.2170e-06 - mean_absolute_error: 0.0021\n","Epoch 15/15\n","27/27 [==============================] - 1s 22ms/step - loss: 9.0399e-06 - mean_absolute_error: 0.0021\n"]},{"output_type":"execute_result","data":{"text/plain":["<keras.callbacks.History at 0x7f9b0bdd5810>"]},"metadata":{},"execution_count":76}]},{"cell_type":"code","source":["# Evaluate the model on the test data using\n","print(\"Evaluate on test data\")\n","results = model.evaluate(X_test, y_test, batch_size=32)\n","print(\"Test MSE:\", results[0])\n","print(\"Test MAE:\", results[1])"],"metadata":{"id":"Sx0u_d6xFGmy","outputId":"d4d9598e-845d-4e87-f4b5-70ed8d93f496","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Evaluate on test data\n","12/12 [==============================] - 1s 7ms/step - loss: 4.3238e-06 - mean_absolute_error: 0.0015\n","Test MSE: 4.323811936046695e-06\n","Test MAE: 0.001464534318074584\n"]}]},{"cell_type":"markdown","source":["MSE and MAE both are less so it seems that model generalize well."],"metadata":{"id":"v1cPs4h_aRB7"}},{"cell_type":"code","source":["\n","# Prediction\n","y_pred = model.predict(X_test)\n","\n","# We create a dataframe from y_pred to have date-time indexes.\n","pred_data = pd.DataFrame(y_pred[:,0], test_original.index,columns=['close'])\n","\n","# Apply inverse transformation from 1.d\n","\n","# Add the differenciation term\n","pred_data['close'] = pred_data['close'] + GL.close_tf.shift().values[-test_days:]\n","\n","# Take the square, and the exponent\n","pred_data = pred_data.apply(np.square)\n","pred_data = pred_data.apply(np.exp)\n","# Plot actual prices vs predicted prices\n","plt.figure(figsize=(10,6))\n","plt.grid(True)\n","plt.xlabel('Dates')\n","plt.ylabel('Closing Prices')\n","plt.plot(test_original,'b',label='Actual prices')\n","plt.plot(pred_data, 'orange',label='Predicted prices')\n","plt.title('date'+ 'close')\n","\n","plt.legend()\n"],"metadata":{"id":"wPjlVHjbFOP9","outputId":"c57a1c10-9939-45f8-a4c8-ef93ef3e3c56","colab":{"base_uri":"https://localhost:8080/","height":421}},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["<matplotlib.legend.Legend at 0x7f9b0bcf5690>"]},"metadata":{},"execution_count":78},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 720x432 with 1 Axes>"]},"metadata":{"needs_background":"light"}}]},{"cell_type":"code","source":["plt.figure(figsize=(10,6))\n","plt.grid(True)\n","plt.xlabel('Dates')\n","plt.ylabel('Closing Prices')\n","plt.plot(train_original, 'b', label='Train data')\n","plt.plot(test_original, 'g', label='Test data')\n","plt.plot(pred_data, 'orange', label='Prediction')\n","plt.title('date' + 'close')\n","plt.legend()\n","\n"],"metadata":{"id":"AhJf7Oos5A7z","outputId":"f9ce2670-6072-4931-85ab-9a28fb12bbc3","colab":{"base_uri":"https://localhost:8080/","height":421}},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["<matplotlib.legend.Legend at 0x7f9a872b7ed0>"]},"metadata":{},"execution_count":79},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 720x432 with 1 Axes>"]},"metadata":{"needs_background":"light"}}]},{"cell_type":"markdown","source":[],"metadata":{"id":"Nv5NdD7laI2L"}},{"cell_type":"markdown","source":["# 15.2 Stacked LSTM"],"metadata":{"id":"ESdRmBY0bEE1"}},{"cell_type":"code","source":["GL1.head()"],"metadata":{