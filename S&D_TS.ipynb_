f col in df.columns:\n","        df[columns].plot(xlabel='date',ylabel='label',legend=True,figsize=(10,4))\n","      return plt.ioff()"],"metadata":{"id":"xhbrMhZwYaCz"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["na= plot(GOOGL, ['open'])\n","na= plot(EBAY, ['open'])\n","na= plot(AAPL, ['open'])"],"metadata":{"id":"HcivUaSLMKuH","outputId":"7e39e3c0-bea5-4ab8-f9ea-de59b49b4688","colab":{"base_uri":"https://localhost:8080/","height":773}},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 720x288 with 1 Axes>"]},"metadata":{"needs_background":"light"}},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 720x288 with 1 Axes>"]},"metadata":{"needs_background":"light"}},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 720x288 with 1 Axes>"]},"metadata":{"needs_background":"light"}}]},{"cell_type":"code","source":["V1= plot(GOOGL, ['close'])\n","V2=plot(EBAY, ['close'])\n","V3=plot(AAPL, ['close'])"],"metadata":{"id":"HnF-92K2Yx2T","outputId":"5bafe290-fb5f-4915-fe56-4d54d6068a14","colab":{"base_uri":"https://localhost:8080/","height":773}},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 720x288 with 1 Axes>"]},"metadata":{"needs_background":"light"}},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 720x288 with 1 Axes>"]},"metadata":{"needs_background":"light"}},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 720x288 with 1 Axes>"]},"metadata":{"needs_background":"light"}}]},{"cell_type":"markdown","source":["-The first transaction of a business  for Google and Apple starts from 2013 to 2018 seems to be growing over time, however in the case of Ebay the opening price starts with a higher price, however in mid-2015 EBAY drops rapidly.\n","\n","-The highest price reached in the day for Google and Apple starts in 2013 to 2018 seems to be growing, however in the case of Ebay the opening price starts with a higher price, however in mid-2015 EBAY drops rapidly.\n","\n","-The highest price reached in the day for Google and Apple starts in 2013 to 2018 seems to be growing, however in the case of Ebay the opening price starts with a higher price, however in mid-2015 EBAY drops rapidly."],"metadata":{"id":"65eN5whGdOxQ"}},{"cell_type":"markdown","source":["#4 Using of Dickey Fuller Test to confirm stationary"],"metadata":{"id":"6XgTDXJOrRlo"}},{"cell_type":"code","source":["from statsmodels.tsa.stattools import adfuller\n","#Test for staionarity\n","def test_stationarity(timeseries):\n","    #Determing rolling statistics\n","    rolmean = timeseries.rolling(12).mean()\n","    rolstd = timeseries.rolling(12).std()\n","    #Plot rolling statistics:\n","    plt.plot(timeseries, color='blue',label='Original')\n","    plt.plot(rolmean, color='red', label='Rolling Mean')\n","    plt.plot(rolstd, color='black', label = 'Rolling Std')\n","    plt.legend(loc='best')\n","    plt.title('Rolling Mean and Standard Deviation')\n","    plt.show(block=False)\n","    print(\"Results of dickey fuller test\")\n","    adft = adfuller(timeseries,autolag='AIC')\n","    # output for dft will give us without defining what the values are.\n","    #hence we manually write what values does it explains using a for loop\n","    output = pd.Series(adft[0:4],index=['Test Statistics','p-value','No. of lags used','Number of observations used'])\n","    for key,values in adft[4].items():\n","        output['critical value (%s)'%key] =  values\n","    print(output)\n"],"metadata":{"id":"17SsrIWDX7ty","outputId":"13faefc0-5d5f-49a3-c1e9-08c96cc7c370","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.7/dist-packages/statsmodels/tools/_testing.py:19: FutureWarning: pandas.util.testing is deprecated. Use the functions in the public API at pandas.testing instead.\n","  import pandas.util.testing as tm\n"]}]},{"cell_type":"code","source":["test_stationarity(GOOGL.close)\n","test_stationarity(EBAY.close)\n","test_stationarity(AAPL.close)"],"metadata":{"id":"ekdRqotrX_Q9","outputId":"9dd25878-0161-4c36-dc82-5c09768c72c3","colab":{"base_uri":"https://localhost:8080/","height":1000}},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 432x288 with 1 Axes>"]},"metadata":{"needs_background":"light"}},{"output_type":"stream","name":"stdout","text":["Results of dickey fuller test\n","Test Statistics                  -0.533822\n","p-value                           0.885246\n","No. of lags used                  1.000000\n","Number of observations used    1257.000000\n","critical value (1%)              -3.435563\n","critical value (5%)              -2.863842\n","critical value (10%)             -2.567996\n","dtype: float64\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 432x288 with 1 Axes>"]},"metadata":{"needs_background":"light"}},{"output_type":"stream","name":"stdout","text":["Results of dickey fuller test\n","Test Statistics                  -1.957238\n","p-value                           0.305632\n","No. of lags used                  0.000000\n","Number of observations used    1258.000000\n","critical value (1%)              -3.435559\n","critical value (5%)              -2.863840\n","critical value (10%)             -2.567995\n","dtype: float64\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 432x288 with 1 Axes>"]},"metadata":{"needs_background":"light"}},{"output_type":"stream","name":"stdout","text":["Results of dickey fuller test\n","Test Statistics                  -0.665091\n","p-value                           0.855586\n","No. of lags used                  0.000000\n","Number of observations used    1258.000000\n","critical value (1%)              -3.435559\n","critical value (5%)              -2.863840\n","critical value (10%)             -2.567995\n","dtype: float64\n"]}]},{"cell_type":"markdown","source":["In case of testing the critical value for opening stock market price,\n","test value for three stock market GOOGL, EBAY and APPL are (-0.5, ,-1.95,and 0.6) is greater than any critical value. In this case, we accept our null hypothesis and conclude that our data is not stationary,\n","\n"],"metadata":{"id":"fDtWja6WBIdN"}},{"cell_type":"markdown","source":["# 5 Another way of testing stationary using KPSS"],"metadata":{"id":"4aa1vkGYIz1j"}},{"cell_type":"code","source":["# Import kpss\n","from statsmodels.tsa.stattools import kpss\n","\n","result = kpss(GL.close)\n","print(result)\n","print('KPSS Test Statistic: %.2f' % result[0])\n","print('5%% Critical Value: %.2f' % result[3]['5%'])\n","print('p-value: %.2f' % result[1])"],"metadata":{"id":"KlMvxj4-Jknv","outputId":"b7cefc8f-19aa-47b0-960c-a26bf62b3a7d","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["(4.879947128873425, 0.01, 23, {'10%': 0.347, '5%': 0.463, '2.5%': 0.574, '1%': 0.739})\n","KPSS Test Statistic: 4.88\n","5% Critical Value: 0.46\n","p-value: 0.01\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.7/dist-packages/statsmodels/tsa/stattools.py:1685: FutureWarning: The behavior of using lags=None will change in the next release. Currently lags=None is the same as lags='legacy', and so a sample-size lag length is used. After the next release, the default will change to be the same as lags='auto' which uses an automatic lag length selection method. To silence this warning, either use 'auto' or 'legacy'\n","  warn(msg, FutureWarning)\n","/usr/local/lib/python3.7/dist-packages/statsmodels/tsa/stattools.py:1709: InterpolationWarning: p-value is smaller than the indicated p-value\n","  warn(\"p-value is smaller than the indicated p-value\", InterpolationWarning)\n"]}]},{"cell_type":"markdown","source":["1. A very important point to note here is that the interpretation of KPSS is entirely opposite of the ADF test, and hence these tests cannot be used interchangeably.\n","  -Null Hypothesis, H0: The time series is stationary.\n","  -Alternative Hypothesis, H1: The time series is not stationary.\n","\n","2. If the p-value is less than or equal to 0.05 or the absolute value of the test statistics is greater than the critical value, you reject H0 and conclude that  the time series is not stationary.\n","\n","3. If the p-value is greater than 0.05 or the absolute value of the test statistics is less than the critical value, you fail to reject H0 and conclude that the time series is stationary.\n","\n","4. In  case of the GOOGL closing price shows that the KPSS test value is higher than any other critical value so we raject the H0 the data is not stationary."],"metadata":{"id":"SvfyDQhBJ_Uc"}},{"cell_type":"markdown","source":["#5 Decompose the time series data with EBay stock"],"metadata":{"id":"r7LSKu1Zd_Ry"}},{"cell_type":"code","source":["from statsmodels.tsa.seasonal import seasonal_decompose"],"metadata":{"id":"5c2_qR5NfBFy"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Drop Null values\n","#EBAY.dropna(inplace=True)\n","#GOOGL.dropna(inplace=True)\n","#GOOGL.dropna(inplace=True)"],"metadata":{"id":"etVgtOZWppDQ"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# 6 Differencing to make the data stationary"],"metadata":{"id":"zNpIbNziOGlv"}},{"cell_type":"code","source":["#making the open price stationary\n","def conv_stat(df, columns):\n","  for col in df.columns:\n","      if col in df.columns:\n","        df['First Difference for open'] = df['open']- df['open'].shift(1)\n","        df['second Difference for open'] = df['open']- df['open'].shift(2)\n","        df['seasonal Difference for open'] = df['open']- df['open'].shift(12)\n","\n","        return df"],"metadata":{"id":"BY_GBD57OD9A"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["GOOGL = conv_stat(GOOGL, open)\n","EBAY = conv_stat(EBAY, open)\n","AAPL= conv_stat(AAPL, open)\n"],"metadata":{"id":"ChlAbr-cQe3n"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["new_GOOGL= (GOOGL['seasonal Difference for open'].dropna())\n","nw_AAPL=(AAPL['seasonal Difference for open'].dropna())\n","new_EBAY=(EBAY['seasonal Difference for open'].dropna())"],"metadata":{"id":"SH3qBSj1Z2SD"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["We can see the test value close value is less for all the critical value  so we  reject the null hypthesis for all three stock market. So the data are stationay."],"metadata":{"id":"o-7zdwoAj6rM"}},{"cell_type":"code","source":["#Plot open data for GOOGL\n","GOOGL['seasonal Difference for open'].plot()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":286},"id":"Q00lhXkMkd7-","outputId":"68f611e3-4130-4d24-f4c4-d6949883d8a5"},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["<matplotlib.axes._subplots.AxesSubplot at 0x7f9b07ab52d0>"]},"metadata":{},"execution_count":21},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 432x288 with 1 Axes>"]},"metadata":{"needs_background":"light"}}]},{"cell_type":"code","source":["#Plot open data for EBAY\n","EBAY['seasonal Difference for open'].plot()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":286},"id":"BQqQRsBnk9zT","outputId":"bdb2849d-d1a7-4339-d7bb-a7d8144be6dd"},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["<matplotlib.axes._subplots.AxesSubplot at 0x7f9b0778c2d0>"]},"metadata":{},"execution_count":22},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 432x288 with 1 Axes>"]},"metadata":{"needs_background":"light"}}]},{"cell_type":"code","source":["#Plot open data for EBAY\n","AAPL['seasonal Difference for open'].plot()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":286},"id":"MuLZwOjzk0cB","outputId":"a246a3b6-6cef-4f05-fb4d-0bd3a1f88966"},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["<matplotlib.axes._subplots.AxesSubplot at 0x7f9b0771fb50>"]},"metadata":{},"execution_count":23},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 432x288 with 1 Axes>"]},"metadata":{"needs_background":"light"}}]},{"cell_type":"code","source":["#making the open price stationary\n","def conv_stat_close(df, columns):\n","  for col in df.columns:\n","      if col in df.columns:\n","        df['First Difference for close'] = df['close']- df['close'].shift(1)\n","        df['second Difference for close'] = df['close']- df['close'].shift(2)\n","        df['seasonal Difference for close'] = df['close']- df['close'].shift(12)\n","        return df"],"metadata":{"id":"4D2kALhXbetz"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["GOOGL = conv_stat_close(GOOGL, ['close'])\n","EBAY = conv_stat_close(EBAY, ['close'])\n","AAPL= conv_stat_close(AAPL, ['close'])"],"metadata":{"id":"VhqzLAN_gPBL"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["(GOOGL['seasonal Difference for close'].dropna())\n","(AAPL['seasonal Difference for close'].dropna())\n","(EBAY['seasonal Difference for close'].dropna())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"wcHxzhbTieqE","outputId":"97dd977b-554b-4393-f857-3c8e37a88994"},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["date\n","2013-02-27   -2.47\n","2013-02-28   -1.70\n","2013-03-01   -1.88\n","2013-03-04   -1.57\n","2013-03-05   -1.57\n","              ... \n","2018-02-01    8.51\n","2018-02-02    6.31\n","2018-02-05    3.63\n","2018-02-06    4.36\n","2018-02-07    2.7