fPHQsDn"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["from sklearn.preprocessing import MinMaxScaler\n","sc= MinMaxScaler(feature_range=(0,1))\n","input_data[:,0:2] = sc.fit_transform(input_feature[:,:])"],"metadata":{"id":"lcZx-3oURH4t"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["lookback= 50\n","\n","test_size=int(.3 * len(data_1))\n","X=[]\n","y=[]\n","for i in range(len(data_1)-lookback-1):\n","    t=[]\n","    for j in range(0,lookback):\n","\n","        t.append(input_data[[(i+j)], :])\n","    X.append(t)\n","    y.append(input_data[i+ lookback,1])"],"metadata":{"id":"5gLGt-Z9R-X4"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["X, y= np.array(X), np.array(y)\n","X_test = X[:test_size+lookback]\n","X = X.reshape(X.shape[0],lookback, 2)\n","X_test = X_test.reshape(X_test.shape[0],lookback, 2)\n","print(X.shape)\n","print(X_test.shape)"],"metadata":{"id":"0WCmcKzsSJT2","outputId":"d99ef2d3-e5db-4f7a-c5d2-cca4d1c22b98","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["(1208, 50, 2)\n","(427, 50, 2)\n"]}]},{"cell_type":"code","source":["from keras import Sequential\n","from keras.layers import Dense, LSTM"],"metadata":{"id":"83zJvwXuSglk"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["model = Sequential()\n","model.add(LSTM(units=30, return_sequences= True, input_shape=(X.shape[1],2)))\n","model.add(LSTM(units=30, return_sequences=True))\n","model.add(LSTM(units=30))\n","model.add(Dense(units=1))\n","model.summary()"],"metadata":{"id":"obRw4dTsSj8D","outputId":"eb0ea7fc-d07c-4a64-ecbe-7b6df2762145","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Model: \"sequential_2\"\n","_________________________________________________________________\n"," Layer (type)                Output Shape              Param #   \n","==